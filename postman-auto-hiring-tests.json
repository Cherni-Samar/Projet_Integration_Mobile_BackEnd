{
  "info": {
    "name": "Auto-Hiring Implementation Tests",
    "description": "Test collection for the onboarding + payment + auto-hiring flow",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "paymentIntentId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Create Test User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test-autohiring@example.com\",\n  \"password\": \"test123456\",\n  \"name\": \"Test Auto Hiring User\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/signup",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "signup"]
        }
      }
    },
    {
      "name": "2. Login User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test-autohiring@example.com\",\n  \"password\": \"test123456\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    const response = pm.response.json();",
              "    pm.collectionVariables.set('authToken', response.data.token);",
              "    console.log('Auth token saved:', response.data.token);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "3. Get Strategic Advice (Dexo Suggestions)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"I run a tech startup that builds mobile apps. We need to scale our team.\"\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/dexo/strategic-advice",
          "host": ["{{baseUrl}}"],
          "path": ["dexo", "strategic-advice"]
        }
      }
    },
    {
      "name": "4. Check Initial My Agents (Should be Empty)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/agents/my-agents",
          "host": ["{{baseUrl}}"],
          "path": ["agents", "my-agents"]
        }
      }
    },
    {
      "name": "5. Create Payment Intent with Suggested Agents",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"packId\": \"basic_plan\",\n  \"suggestedAgents\": [\"hera\", \"echo\"]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/payment/create-payment-intent",
          "host": ["{{baseUrl}}"],
          "path": ["payment", "create-payment-intent"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    const response = pm.response.json();",
              "    pm.collectionVariables.set('paymentIntentId', response.paymentIntentId);",
              "    console.log('Payment Intent ID saved:', response.paymentIntentId);",
              "    console.log('Suggested Agents:', response.suggestedAgents);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "6. Confirm Payment (Auto-Hire Agents)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"paymentIntentId\": \"{{paymentIntentId}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/payment/confirm-payment",
          "host": ["{{baseUrl}}"],
          "path": ["payment", "confirm-payment"]
        }
      }
    },
    {
      "name": "7. Check My Agents After Payment (Should Show Hired Agents)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/agents/my-agents",
          "host": ["{{baseUrl}}"],
          "path": ["agents", "my-agents"]
        }
      }
    },
    {
      "name": "8. Try Manual Hiring (Should Respect Limits)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"agentId\": \"kash\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/agents/hire",
          "host": ["{{baseUrl}}"],
          "path": ["agents", "hire"]
        }
      }
    },
    {
      "name": "9. Test Edge Case: Duplicate Agents",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"packId\": \"premium_plan\",\n  \"suggestedAgents\": [\"hera\", \"hera\", \"echo\", \"echo\", \"kash\"]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/payment/create-payment-intent",
          "host": ["{{baseUrl}}"],
          "path": ["payment", "create-payment-intent"]
        }
      }
    },
    {
      "name": "10. Test Edge Case: Invalid Agents",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"packId\": \"basic_plan\",\n  \"suggestedAgents\": [\"hera\", \"invalid_agent\", \"echo\", \"fake_agent\"]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/payment/create-payment-intent",
          "host": ["{{baseUrl}}"],
          "path": ["payment", "create-payment-intent"]
        }
      }
    },
    {
      "name": "11. Test Limit Enforcement: 4 Agents on 3-Agent Plan",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"packId\": \"basic_plan\",\n  \"suggestedAgents\": [\"hera\", \"echo\", \"kash\", \"dexo\"]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/payment/create-payment-intent",
          "host": ["{{baseUrl}}"],
          "path": ["payment", "create-payment-intent"]
        }
      }
    },
    {
      "name": "12. Get All Agents (Marketplace View)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/agents",
          "host": ["{{baseUrl}}"],
          "path": ["agents"]
        }
      }
    }
  ]
}